<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>J.R. — Solicitud de Apoyo</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root {
            --azul: #001a70; --celeste: #e8f0fe; --blanco: #ffffff;
            --rojo: #dc2626; --verde: #10b981; --naranja: #f59e0b;
            --gris: #64748b; --fondo: #f0f4ff;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--fondo); font-family: 'DM Sans', sans-serif; padding: 15px; color: #1e293b; }
        .container { max-width: 650px; margin: 0 auto; }

        /* HEADER */
        .top-bar {
            display: flex; align-items: center; justify-content: space-between;
            background: var(--blanco); border-radius: 16px; padding: 14px 18px;
            margin-bottom: 18px; box-shadow: 0 2px 8px rgba(0,26,112,0.06);
        }
        .top-bar-left { display: flex; align-items: center; gap: 10px; }
        .top-bar h1 { font-size: 15px; font-weight: 800; color: var(--azul); }
        .top-bar small { font-size: 11px; color: var(--gris); display: block; }
        .btn-volver { background: var(--fondo); border: none; color: var(--gris); font-weight: 700; font-size: 13px; cursor: pointer; padding: 8px 12px; border-radius: 10px; }

        /* TABS */
        .tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 18px; }
        .tab-btn {
            padding: 12px; border-radius: 12px; border: 2px solid transparent;
            font-weight: 700; font-size: 13px; cursor: pointer; transition: 0.2s;
            background: var(--blanco); color: var(--gris);
        }
        .tab-btn.active { background: var(--azul); color: white; border-color: var(--azul); }

        /* PANEL */
        .panel { display: none; }
        .panel.activo { display: block; }

        /* CARD FORM */
        .card {
            background: var(--blanco); border-radius: 16px; padding: 20px;
            margin-bottom: 14px; box-shadow: 0 2px 8px rgba(0,26,112,0.05);
        }
        .card-title {
            font-size: 11px; font-weight: 800; color: var(--azul); text-transform: uppercase;
            letter-spacing: 0.8px; margin-bottom: 14px; padding-bottom: 10px;
            border-bottom: 1.5px solid var(--fondo);
        }
        .form-group { margin-bottom: 12px; }
        label { display: block; font-size: 11px; font-weight: 700; color: var(--gris); margin-bottom: 4px; text-transform: uppercase; }
        input, select, textarea {
            width: 100%; padding: 11px 13px; border: 1.5px solid #e2e8f0;
            border-radius: 10px; font-family: inherit; font-size: 14px;
            color: #1e293b; background: var(--fondo); transition: 0.15s;
        }
        input:focus, select:focus, textarea:focus { outline: none; border-color: var(--azul); background: white; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

        /* URGENCIA PILLS */
        .urgencia-row { display: flex; gap: 8px; margin-top: 4px; }
        .u-pill {
            flex: 1; padding: 10px 6px; border-radius: 10px; border: 2px solid #e2e8f0;
            background: var(--fondo); font-weight: 700; font-size: 12px;
            cursor: pointer; text-align: center; transition: 0.15s;
        }
        .u-pill.sel-normal  { border-color: var(--verde);  background: #ecfdf5; color: #065f46; }
        .u-pill.sel-urgente { border-color: var(--naranja); background: #fffbeb; color: #92400e; }
        .u-pill.sel-critica { border-color: var(--rojo);   background: #fef2f2; color: #991b1b; }

        /* ALCANCE PILLS */
        .alcance-row { display: flex; gap: 8px; margin-top: 4px; }
        .a-pill {
            flex: 1; padding: 11px 6px; border-radius: 10px; border: 2px solid #e2e8f0;
            background: var(--fondo); font-weight: 700; font-size: 13px;
            cursor: pointer; text-align: center; transition: 0.15s;
        }
        .a-pill.sel { border-color: var(--azul); background: var(--celeste); color: var(--azul); }

        /* BTN ENVIAR */
        .btn-enviar {
            width: 100%; padding: 15px; border: none; border-radius: 13px;
            background: var(--azul); color: white; font-weight: 800; font-size: 15px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            gap: 10px; box-shadow: 0 4px 14px rgba(0,26,112,0.2); transition: 0.2s;
        }
        .btn-enviar:active { transform: scale(0.98); }
        .btn-enviar:disabled { opacity: 0.5; cursor: not-allowed; }

        /* SOLICITUDES LIST */
        .solicitud-card {
            background: var(--blanco); border-radius: 16px; padding: 18px;
            margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,26,112,0.05);
            border-left: 4px solid var(--azul); transition: 0.2s;
            position: relative; overflow: hidden;
        }
        .solicitud-card.urgente { border-left-color: var(--naranja); }
        .solicitud-card.critica { border-left-color: var(--rojo); }
        .solicitud-card.aceptada { border-left-color: var(--verde); opacity: 0.75; }

        .sol-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
        .sol-regional { font-weight: 800; font-size: 16px; color: var(--azul); }
        .sol-tiempo { font-size: 10px; color: var(--gris); text-align: right; }

        .sol-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
        .badge {
            font-size: 10px; font-weight: 700; padding: 3px 9px;
            border-radius: 6px; text-transform: uppercase;
        }
        .badge-pendiente  { background: #eff6ff; color: #1d4ed8; }
        .badge-aceptada   { background: #ecfdf5; color: #065f46; }
        .badge-en_curso   { background: #fff7ed; color: #c2410c; }
        .badge-completada { background: #f1f5f9; color: #475569; }
        .badge-urgente    { background: #fffbeb; color: #92400e; }
        .badge-critica    { background: #fef2f2; color: #991b1b; }
        .badge-nacional   { background: #f5f3ff; color: #6d28d9; }
        .badge-regional   { background: #ecfdf5; color: #065f46; }

        .sol-info { font-size: 13px; color: #475569; line-height: 1.6; margin-bottom: 12px; }
        .sol-info b { color: #1e293b; }

        .sol-ruta {
            display: flex; align-items: center; gap: 6px;
            background: var(--fondo); padding: 8px 12px; border-radius: 8px;
            font-size: 12px; font-weight: 700; color: var(--azul); margin-bottom: 12px;
        }

        .btn-aceptar {
            width: 100%; padding: 13px; border: none; border-radius: 11px;
            background: var(--verde); color: white; font-weight: 800; font-size: 14px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            gap: 8px; transition: 0.2s;
        }
        .btn-aceptar:active { transform: scale(0.98); }
        .btn-ya-aceptada {
            width: 100%; padding: 12px; border: 1.5px solid #e2e8f0; border-radius: 11px;
            background: white; color: var(--gris); font-weight: 700; font-size: 13px;
            cursor: not-allowed; text-align: center;
        }

        /* FILTROS */
        .filtros { display: flex; gap: 8px; margin-bottom: 14px; overflow-x: auto; padding-bottom: 4px; }
        .filtro-btn {
            padding: 7px 14px; border-radius: 8px; border: 1.5px solid #e2e8f0;
            background: white; font-size: 12px; font-weight: 700; color: var(--gris);
            cursor: pointer; white-space: nowrap; transition: 0.15s; flex-shrink: 0;
        }
        .filtro-btn.activo { background: var(--azul); color: white; border-color: var(--azul); }

        /* EMPTY */
        .empty { text-align: center; padding: 40px 20px; color: var(--gris); }
        .empty .icon { font-size: 40px; margin-bottom: 10px; }
        .empty p { font-size: 14px; }

        /* TOAST */
        .toast {
            position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%) translateY(60px);
            background: #1e293b; color: white; padding: 12px 20px; border-radius: 12px;
            font-size: 13px; font-weight: 600; z-index: 999; opacity: 0; transition: 0.3s;
            white-space: nowrap; box-shadow: 0 4px 14px rgba(0,0,0,0.2);
        }
        .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
    </style>
</head>
<body>
<div class="container">

    <!-- TOP BAR -->
    <div class="top-bar">
        <div class="top-bar-left">
            <div>
                <h1>🤝 Solicitudes de Apoyo</h1>
                <small id="user-subtitle">Cargando...</small>
            </div>
        </div>
        <button class="btn-volver" onclick="irAtras()">← Volver</button>
    </div>

    <!-- TABS -->
    <div class="tabs">
        <button class="tab-btn active" id="tab-ver" onclick="switchTab('ver')">📋 Ver Solicitudes</button>
        <button class="tab-btn" id="tab-crear" onclick="switchTab('crear')">➕ Crear Solicitud</button>
    </div>

    <!-- ══ PANEL VER ══ -->
    <div class="panel activo" id="panel-ver">

        <div class="filtros">
            <button class="filtro-btn activo" onclick="setFiltro('todos', this)">Todos</button>
            <button class="filtro-btn" onclick="setFiltro('pendiente', this)">⏳ Pendientes</button>
            <button class="filtro-btn" onclick="setFiltro('mi_regional', this)">📍 Mi Regional</button>
            <button class="filtro-btn" onclick="setFiltro('nacional', this)">🌎 Nacional</button>
            <button class="filtro-btn" onclick="setFiltro('aceptada', this)">✅ Aceptadas</button>
        </div>

        <div id="lista-solicitudes">
            <div class="empty"><div class="icon">⏳</div><p>Cargando solicitudes...</p></div>
        </div>
    </div>

    <!-- ══ PANEL CREAR ══ -->
    <div class="panel" id="panel-crear">

        <div class="card">
            <div class="card-title">📍 Datos de la Solicitud</div>

            <div class="form-group">
                <label>Coordinador Solicitante</label>
                <input type="text" id="c-coordinador" readonly style="background:#eef5ff; font-weight:700;">
            </div>
            <div class="grid-2">
                <div class="form-group">
                    <label>Regional Solicitante</label>
                    <input type="text" id="c-regional" readonly style="background:#eef5ff; font-weight:700;">
                </div>
                <div class="form-group">
                    <label>Tipo de Servicio</label>
                    <select id="c-tipo">
                        <option value="Servicio Funerario">Servicio Funerario</option>
                        <option value="Traslado Nacional">Traslado Nacional</option>
                        <option value="Recogida Clínica">Recogida Clínica</option>
                        <option value="Traslado de Emergencia">Traslado de Emergencia</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">⚱️ Datos del Servicio</div>
            <div class="form-group">
                <label>Nombre del Fallecido</label>
                <input type="text" id="c-fallecido" placeholder="Nombre completo (opcional)">
            </div>
            <div class="form-group">
                <label>Clínica / Hospital / RSD</label>
                <input type="text" id="c-clinica" placeholder="Lugar de recogida">
            </div>
            <div class="grid-2">
                <div class="form-group">
                    <label>Origen</label>
                    <input type="text" id="c-origen" placeholder="Ciudad de salida">
                </div>
                <div class="form-group">
                    <label>Destino</label>
                    <input type="text" id="c-destino" placeholder="Ciudad de llegada">
                </div>
            </div>
            <div class="grid-2">
                <div class="form-group">
                    <label>Fecha del Servicio</label>
                    <input type="date" id="c-fecha">
                </div>
                <div class="form-group">
                    <label>Hora Requerida</label>
                    <input type="time" id="c-hora">
                </div>
            </div>
            <div class="form-group">
                <label>Observaciones</label>
                <textarea id="c-obs" rows="2" placeholder="Detalles adicionales para el conductor..."></textarea>
            </div>
        </div>

        <div class="card">
            <div class="card-title">🚨 Urgencia</div>
            <div class="urgencia-row">
                <div class="u-pill sel-normal" id="u-normal" onclick="setUrgencia('normal')">✅ Normal</div>
                <div class="u-pill" id="u-urgente" onclick="setUrgencia('urgente')">⚡ Urgente</div>
                <div class="u-pill" id="u-critica" onclick="setUrgencia('critica')">🚨 Crítica</div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">🌎 Alcance del Apoyo</div>
            <div class="alcance-row">
                <div class="a-pill sel" id="a-regional" onclick="setAlcance('regional')">📍 Solo mi Regional</div>
                <div class="a-pill" id="a-nacional" onclick="setAlcance('nacional')">🌎 Nacional (todas)</div>
            </div>
            <p style="font-size:11px; color:var(--gris); margin-top:10px; line-height:1.5;">
                <b>Regional:</b> solo conductores de <span id="texto-regional-alcance">tu regional</span> verán esta solicitud.<br>
                <b>Nacional:</b> todos los conductores del país podrán aceptarla.
            </p>
        </div>

        <button class="btn-enviar" id="btn-crear" onclick="crearSolicitud()">
            <span>📤</span> ENVIAR SOLICITUD DE APOYO
        </button>
        <div style="height:15px;"></div>
    </div>

</div>

<div class="toast" id="toast"></div>

<script src="db.js"></script>
<script>
    let sesion = {};
    let urgenciaActual = 'normal';
    let alcanceActual = 'regional';
    let filtroActual = 'todos';
    let todasSolicitudes = [];

    // ── INIT ──
    window.onload = async () => {
        sesion = JSON.parse(localStorage.getItem('usuario_sesion') || '{}');
        if (!sesion.nombre) { window.location.href = 'index.html'; return; }

        document.getElementById('c-coordinador').value = sesion.nombre;
        const regional = localStorage.getItem('jr_regional_usuario') || sesion.regional || 'Pereira';
        document.getElementById('c-regional').value = regional;
        document.getElementById('texto-regional-alcance').textContent = regional;
        document.getElementById('user-subtitle').textContent = sesion.nombre + ' · ' + regional;

        // Fecha hoy por defecto
        document.getElementById('c-fecha').valueAsDate = new Date();

        await cargarSolicitudes();

        // Auto-refresh cada 30 segundos
        setInterval(cargarSolicitudes, 30000);
    };

    // ── NAV ──
    function irAtras() {
        const esAdmin = (sesion.usuario||'').toLowerCase()==='admin' || (sesion.rol||'').toLowerCase()==='admin';
        window.location.href = esAdmin ? 'dashboard.html' : 'panel_conductor.html';
    }

    function switchTab(tab) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.panel').forEach(p => p.classList.remove('activo'));
        document.getElementById('tab-' + tab).classList.add('active');
        document.getElementById('panel-' + tab).classList.add('activo');
        if (tab === 'ver') cargarSolicitudes();
    }

    // ── FILTROS ──
    function setFiltro(f, el) {
        filtroActual = f;
        document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('activo'));
        el.classList.add('activo');
        renderSolicitudes();
    }

    // ── URGENCIA ──
    function setUrgencia(u) {
        urgenciaActual = u;
        ['normal','urgente','critica'].forEach(x => {
            const el = document.getElementById('u-' + x);
            el.className = 'u-pill' + (x === u ? ' sel-' + x : '');
        });
    }

    // ── ALCANCE ──
    function setAlcance(a) {
        alcanceActual = a;
        ['regional','nacional'].forEach(x => {
            document.getElementById('a-' + x).className = 'a-pill' + (x === a ? ' sel' : '');
        });
    }

    // ── CARGAR SOLICITUDES ──
    async function cargarSolicitudes() {
        try {
            const { data, error } = await DB.supabase
                .from('solicitudes_apoyo')
                .select('*')
                .order('created_at', { ascending: false })
                .limit(50);
            if (error) throw error;
            todasSolicitudes = data || [];
            renderSolicitudes();
        } catch(e) {
            document.getElementById('lista-solicitudes').innerHTML =
                '<div class="empty"><div class="icon">❌</div><p>Error al cargar: ' + e.message + '</p></div>';
        }
    }

    // ── RENDER ──
    function renderSolicitudes() {
        const regionalUsuario = document.getElementById('c-regional').value;
        let lista = todasSolicitudes;

        // Aplicar filtro
        if (filtroActual === 'pendiente')   lista = lista.filter(s => s.estado === 'pendiente');
        if (filtroActual === 'aceptada')    lista = lista.filter(s => s.estado === 'aceptada' || s.estado === 'en_curso');
        if (filtroActual === 'mi_regional') lista = lista.filter(s => s.regional_solicitante === regionalUsuario);
        if (filtroActual === 'nacional')    lista = lista.filter(s => s.alcance === 'nacional');

        // Solo mostrar las relevantes para este usuario
        // (su regional o nacionales)
        lista = lista.filter(s =>
            s.alcance === 'nacional' ||
            s.regional_solicitante === regionalUsuario ||
            filtroActual !== 'todos'
        );

        const div = document.getElementById('lista-solicitudes');
        if (!lista.length) {
            div.innerHTML = '<div class="empty"><div class="icon">📭</div><p>No hay solicitudes en este filtro</p></div>';
            return;
        }

        div.innerHTML = lista.map(s => {
            const yaAceptada = s.estado !== 'pendiente';
            const esLaMia = s.coordinador === sesion.nombre;
            const tiempoAtras = calcularTiempo(s.created_at);

            const colorCard = s.urgencia === 'critica' ? 'critica' : s.urgencia === 'urgente' ? 'urgente' : yaAceptada ? 'aceptada' : '';

            return `
            <div class="solicitud-card ${colorCard}" id="sol-${s.id}">
                <div class="sol-header">
                    <div>
                        <div class="sol-regional">📍 ${s.regional_solicitante}</div>
                        <div style="font-size:12px; color:var(--gris); margin-top:2px;">por ${s.coordinador}</div>
                    </div>
                    <div class="sol-tiempo">${tiempoAtras}</div>
                </div>

                <div class="sol-badges">
                    <span class="badge badge-${s.estado}">${estadoLabel(s.estado)}</span>
                    ${s.urgencia !== 'normal' ? `<span class="badge badge-${s.urgencia}">${s.urgencia === 'urgente' ? '⚡ Urgente' : '🚨 Crítica'}</span>` : ''}
                    <span class="badge badge-${s.alcance}">${s.alcance === 'nacional' ? '🌎 Nacional' : '📍 Regional'}</span>
                    <span class="badge" style="background:#f0f9ff;color:#0369a1;">${s.tipo_servicio}</span>
                </div>

                ${(s.origen && s.destino) ? `
                <div class="sol-ruta">
                    🚩 ${s.origen} <span style="color:var(--gris);">────➔</span> 🏁 ${s.destino}
                </div>` : ''}

                <div class="sol-info">
                    ${s.nombre_fallecido ? `<b>⚱️ Fallecido:</b> ${s.nombre_fallecido}<br>` : ''}
                    ${s.clinica_hospital ? `<b>🏥 Lugar:</b> ${s.clinica_hospital}<br>` : ''}
                    ${s.fecha_servicio   ? `<b>📅 Fecha:</b> ${s.fecha_servicio}${s.hora_requerida ? ' · ' + s.hora_requerida : ''}<br>` : ''}
                    ${s.conductor_aceptó ? `<b>👤 Conductor:</b> ${s.conductor_aceptó}<br>` : ''}
                    ${s.observaciones    ? `<b>📝</b> ${s.observaciones}` : ''}
                </div>

                ${!yaAceptada && !esLaMia ? `
                <button class="btn-aceptar" onclick="aceptarApoyo(${s.id})">
                    <span>🤝</span> ACEPTAR Y LLENAR SALIDA
                </button>` : ''}

                ${yaAceptada ? `
                <div class="btn-ya-aceptada">
                    ${s.estado === 'aceptada' ? '✅ Aceptada por ' + (s.conductor_aceptó || '---') :
                      s.estado === 'en_curso'  ? '🚗 En curso — ' + (s.conductor_aceptó || '---') :
                      '✔️ Completada'}
                </div>` : ''}

                ${esLaMia && s.estado === 'pendiente' ? `
                <button onclick="cancelarSolicitud(${s.id})" style="width:100%; padding:10px; border:1.5px solid #fee2e2; border-radius:10px; background:white; color:var(--rojo); font-weight:700; font-size:12px; cursor:pointer; margin-top:8px;">
                    🗑️ Cancelar mi solicitud
                </button>` : ''}
            </div>`;
        }).join('');
    }

    // ── CREAR SOLICITUD ──
    async function crearSolicitud() {
        const btn = document.getElementById('btn-crear');
        const origen = document.getElementById('c-origen').value.trim();
        const destino = document.getElementById('c-destino').value.trim();

        if (!origen || !destino) {
            toast('⚠️ Origen y Destino son obligatorios', '#f59e0b'); return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span>⏳</span> ENVIANDO...';

        const datos = {
            regional_solicitante: document.getElementById('c-regional').value,
            coordinador:          document.getElementById('c-coordinador').value,
            tipo_servicio:        document.getElementById('c-tipo').value,
            nombre_fallecido:     document.getElementById('c-fallecido').value.trim(),
            clinica_hospital:     document.getElementById('c-clinica').value.trim(),
            origen,
            destino,
            fecha_servicio:       document.getElementById('c-fecha').value,
            hora_requerida:       document.getElementById('c-hora').value,
            observaciones:        document.getElementById('c-obs').value.trim(),
            urgencia:             urgenciaActual,
            alcance:              alcanceActual,
            estado:               'pendiente'
        };

        try {
            const { error } = await DB.supabase.from('solicitudes_apoyo').insert([datos]);
            if (error) throw error;

            btn.innerHTML = '<span>✅</span> SOLICITUD ENVIADA';
            btn.style.background = '#10b981';
            toast('✅ Solicitud creada — los conductores ya pueden verla', '#10b981');

            // Limpiar form
            setTimeout(() => {
                document.getElementById('c-fallecido').value = '';
                document.getElementById('c-clinica').value = '';
                document.getElementById('c-origen').value = '';
                document.getElementById('c-destino').value = '';
                document.getElementById('c-obs').value = '';
                document.getElementById('c-hora').value = '';
                document.getElementById('c-fecha').valueAsDate = new Date();
                setUrgencia('normal');
                setAlcance('regional');
                btn.disabled = false;
                btn.innerHTML = '<span>📤</span> ENVIAR SOLICITUD DE APOYO';
                btn.style.background = '';
                switchTab('ver');
            }, 1500);

        } catch(e) {
            toast('❌ Error: ' + e.message, '#dc2626');
            btn.disabled = false;
            btn.innerHTML = '<span>📤</span> ENVIAR SOLICITUD DE APOYO';
        }
    }

    // ── ACEPTAR APOYO ──
    async function aceptarApoyo(id) {
        const sol = todasSolicitudes.find(s => s.id === id);
        if (!sol) return;

        // Confirmar
        if (!confirm('¿Aceptas este servicio de apoyo?\n\nRuta: ' + sol.origen + ' → ' + sol.destino + '\n\nSe abrirá el formulario de salida con los datos prellenados.')) return;

        // Marcar como aceptada en Supabase
        const { error } = await DB.supabase
            .from('solicitudes_apoyo')
            .update({ estado: 'aceptada', 'conductor_aceptó': sesion.nombre })
            .eq('id', id);

        if (error) { toast('❌ Error al aceptar: ' + error.message, '#dc2626'); return; }

        toast('✅ Apoyo aceptado — abriendo formulario de salida...', '#10b981');

        // Guardar datos de la solicitud en localStorage para pre-llenar el formulario
        localStorage.setItem('apoyo_prellenado', JSON.stringify({
            solicitud_id:   id,
            fallecido:      sol.nombre_fallecido || '',
            clinica:        sol.clinica_hospital || '',
            origen:         sol.origen || '',
            destino:        sol.destino || '',
            motivo:         sol.tipo_servicio || 'Servicio Funerario',
            coordinador:    sol.coordinador || '',
            observaciones:  sol.observaciones || ''
        }));

        setTimeout(() => {
            window.location.href = 'registro_salida.html';
        }, 1200);
    }

    // ── CANCELAR SOLICITUD ──
    async function cancelarSolicitud(id) {
        if (!confirm('¿Cancelar esta solicitud?')) return;
        const { error } = await DB.supabase
            .from('solicitudes_apoyo').delete().eq('id', id);
        if (error) { toast('❌ ' + error.message, '#dc2626'); return; }
        toast('🗑️ Solicitud cancelada', '#64748b');
        cargarSolicitudes();
    }

    // ── HELPERS ──
    function estadoLabel(e) {
        return { pendiente:'⏳ Pendiente', aceptada:'✅ Aceptada', en_curso:'🚗 En Curso', completada:'✔️ Completada' }[e] || e;
    }

    function calcularTiempo(ts) {
        if (!ts) return '---';
        const diff = Date.now() - new Date(ts).getTime();
        const m = Math.floor(diff / 60000);
        if (m < 1)  return 'Ahora mismo';
        if (m < 60) return 'Hace ' + m + ' min';
        const h = Math.floor(m / 60);
        if (h < 24) return 'Hace ' + h + 'h';
        return 'Hace ' + Math.floor(h/24) + 'd';
    }

    function toast(msg, color) {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.style.background = color || '#1e293b';
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
    }
</script>
<script src="config-aplicar.js"></script>
